{
  "projeto": {
    "nome": "bot-whatsapp",
    "pacote": "br.com.sistema.bot",
    "descricao": "Backend orquestrador do bot de atendimento WhatsApp da ASB Telecom",
    "apiBaseUrl": "/api/v1",
    "contextPath": "/api/v1"
  },

  "enums": [
    {
      "nome": "ConversationLabel",
      "valores": [
        "SELECT_MENU_INICIAL",
        "SELECT_SOU_CLIENTE",
        "SELECT_FINANCEIRO",
        "SELECT_SUPORTE",
        "SELECT_DUVIDAS",
        "SELECT_CANCELAMENTO",
        "INPUT_CPF_CNPJ",
        "CONFIRMA_CPF",
        "FATURA",
        "DESBLOQUEIO"
      ]
    },
    {
      "nome": "TeamId",
      "valores": [
        "FINANCEIRO",
        "SUPORTE",
        "DUVIDAS_COMERCIAL",
        "CANCELAMENTO"
      ]
    }
  ],

  "dtos": {
    "requests": [
      {
        "nome": "ChatwootWebhookRequest",
        "descricao": "Payload principal do webhook enviado pelo Chatwoot",
        "campos": [
          { "nome": "event",    "tipo": "String",  "obrigatorio": false, "validacoes": [] },
          { "nome": "id",       "tipo": "Long",    "obrigatorio": false, "validacoes": [] },
          { "nome": "inboxId",  "tipo": "Integer", "obrigatorio": false, "validacoes": [] },
          { "nome": "labels",   "tipo": "List<String>", "obrigatorio": false, "validacoes": [] },
          { "nome": "messages", "tipo": "List<ChatwootMessageRequest>", "obrigatorio": false, "validacoes": [] },
          { "nome": "meta",     "tipo": "ChatwootMetaRequest", "obrigatorio": false, "validacoes": [] }
        ]
      },
      {
        "nome": "ChatwootMessageRequest",
        "descricao": "Mensagem individual dentro do webhook do Chatwoot",
        "campos": [
          { "nome": "id",          "tipo": "Long",    "obrigatorio": false, "validacoes": [] },
          { "nome": "content",     "tipo": "String",  "obrigatorio": false, "validacoes": [] },
          { "nome": "messageType", "tipo": "Integer", "obrigatorio": false, "validacoes": [] },
          { "nome": "contentType", "tipo": "String",  "obrigatorio": false, "validacoes": [] },
          { "nome": "sender",      "tipo": "ChatwootSenderRequest", "obrigatorio": false, "validacoes": [] }
        ]
      },
      {
        "nome": "ChatwootSenderRequest",
        "descricao": "Dados do remetente da mensagem",
        "campos": [
          { "nome": "name",        "tipo": "String", "obrigatorio": false, "validacoes": [] },
          { "nome": "phoneNumber", "tipo": "String", "obrigatorio": false, "validacoes": [] },
          { "nome": "identifier",  "tipo": "String", "obrigatorio": false, "validacoes": [] }
        ]
      },
      {
        "nome": "ChatwootMetaRequest",
        "descricao": "Metadados da conversa (assignee = null indica sem atendente humano)",
        "campos": [
          { "nome": "assignee", "tipo": "Object", "obrigatorio": false, "validacoes": [] }
        ]
      }
    ],
    "responses": [
      {
        "nome": "HubsoftTokenResponse",
        "campos": [
          { "nome": "accessToken", "tipo": "String"  },
          { "nome": "expiresIn",   "tipo": "Integer" },
          { "nome": "tokenType",   "tipo": "String"  }
        ]
      },
      {
        "nome": "HubsoftClienteResponse",
        "campos": [
          { "nome": "clientes", "tipo": "List<HubsoftClienteItem>" }
        ]
      },
      {
        "nome": "HubsoftClienteItem",
        "campos": [
          { "nome": "nomeRazaosocial", "tipo": "String" },
          { "nome": "cpfCnpj",        "tipo": "String" },
          { "nome": "servicos",        "tipo": "List<HubsoftServicoItem>" }
        ]
      },
      {
        "nome": "HubsoftServicoItem",
        "campos": [
          { "nome": "id",        "tipo": "Long"   },
          { "nome": "descricao", "tipo": "String" },
          { "nome": "status",    "tipo": "String" },
          { "nome": "idCliente", "tipo": "Long"   }
        ]
      },
      {
        "nome": "HubsoftFaturaResponse",
        "campos": [
          { "nome": "faturas", "tipo": "List<HubsoftFaturaItem>" }
        ]
      },
      {
        "nome": "HubsoftFaturaItem",
        "campos": [
          { "nome": "dataVencimento", "tipo": "String" },
          { "nome": "linhaDigitavel", "tipo": "String" },
          { "nome": "link",           "tipo": "String" },
          { "nome": "detalhamento",   "tipo": "String" }
        ]
      },
      {
        "nome": "HubsoftDesbloqueioResponse",
        "campos": [
          { "nome": "status",  "tipo": "String" },
          { "nome": "message", "tipo": "String" }
        ]
      },
      {
        "nome": "ChatwootMessagesResponse",
        "campos": [
          { "nome": "payload", "tipo": "List<ChatwootMessageRequest>" }
        ]
      }
    ]
  },

  "endpoints": [
    {
      "tag": "Webhook",
      "descricao": "Recebimento de eventos do Chatwoot para processamento do bot de atendimento",
      "rotas": [
        {
          "metodo": "POST",
          "path": "/webhook/chatwoot",
          "operacao": "Receber evento do Chatwoot",
          "descricao": "Valida assinatura HMAC-SHA256 (header x-hub-signature-256) e delega ao WebhookService. Filtra apenas mensagens recebidas (message_type=0) sem atendente humano (assignee=null).",
          "requestDto": "ChatwootWebhookRequest",
          "responseDto": null,
          "responseStatus": 200,
          "autenticacao": true
        }
      ]
    }
  ]
}
