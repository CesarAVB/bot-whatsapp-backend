{
  "projeto": {
    "nome": "bot-whatsapp",
    "pacote": "br.com.sistema.bot",
    "descricao": "Painel administrativo do bot de atendimento WhatsApp da ASB Telecom",
    "apiBaseUrl": "/api/v1",
    "contextPath": "/api/v1"
  },

  "enums": [
    {
      "nome": "BotState",
      "valores": [
        "MENU_INICIAL",
        "SOU_CLIENTE",
        "FINANCEIRO",
        "AGUARDA_CPF_FATURA",
        "AGUARDA_CPF_DESBLOQUEIO",
        "CONFIRMA_IDENTIDADE_FATURA",
        "CONFIRMA_IDENTIDADE_DESBLOQUEIO",
        "TRANSFERIDO",
        "ENCERRADO"
      ]
    },
    {
      "nome": "TipoNode",
      "valores": [
        "MENU",
        "AGUARDA_INPUT",
        "CONFIRMACAO",
        "TRANSFERENCIA",
        "RESULTADO_API",
        "MENSAGEM",
        "ENCERRAMENTO"
      ]
    },
    {
      "nome": "Direcao",
      "valores": [
        "RECEBIDA",
        "ENVIADA"
      ]
    }
  ],

  "dtos": {
    "requests": [
      {
        "nome": "AtualizarTemplateRequest",
        "descricao": "Payload para atualizar o texto de um template de mensagem",
        "campos": [
          { "nome": "texto",      "tipo": "String", "obrigatorio": true,  "validacoes": ["NotBlank"] },
          { "nome": "alteradoPor","tipo": "String", "obrigatorio": false, "validacoes": ["Size(max=100)"] }
        ]
      }
    ],
    "responses": [
      {
        "nome": "BotTemplateResponse",
        "campos": [
          { "nome": "chave",     "tipo": "String"        },
          { "nome": "texto",     "tipo": "String"        },
          { "nome": "descricao", "tipo": "String"        },
          { "nome": "ativo",     "tipo": "boolean"       },
          { "nome": "createdAt", "tipo": "LocalDateTime" },
          { "nome": "updatedAt", "tipo": "LocalDateTime" }
        ]
      },
      {
        "nome": "BotTemplateAuditoriaResponse",
        "campos": [
          { "nome": "templateChave",  "tipo": "String"        },
          { "nome": "textoAnterior",  "tipo": "String"        },
          { "nome": "textoNovo",      "tipo": "String"        },
          { "nome": "alteradoPor",    "tipo": "String"        },
          { "nome": "alteradoEm",     "tipo": "LocalDateTime" }
        ]
      },
      {
        "nome": "MensagemHistoricoResponse",
        "campos": [
          { "nome": "direcao",   "tipo": "Direcao"       },
          { "nome": "conteudo",  "tipo": "String"        },
          { "nome": "createdAt", "tipo": "LocalDateTime" }
        ]
      },
      {
        "nome": "ConversaResumoResponse",
        "campos": [
          { "nome": "whatsappPhone",         "tipo": "String"        },
          { "nome": "currentState",          "tipo": "BotState"      },
          { "nome": "chatwootConversationId","tipo": "Long"          },
          { "nome": "createdAt",             "tipo": "LocalDateTime" },
          { "nome": "updatedAt",             "tipo": "LocalDateTime" }
        ]
      },
      {
        "nome": "ConversaDetalheResponse",
        "campos": [
          { "nome": "whatsappPhone",         "tipo": "String"                        },
          { "nome": "currentState",          "tipo": "BotState"                      },
          { "nome": "chatwootConversationId","tipo": "Long"                          },
          { "nome": "createdAt",             "tipo": "LocalDateTime"                 },
          { "nome": "updatedAt",             "tipo": "LocalDateTime"                 },
          { "nome": "historico",             "tipo": "List<MensagemHistoricoResponse>"}
        ]
      },
      {
        "nome": "DashboardMetricasResponse",
        "campos": [
          { "nome": "totalPorEstado", "tipo": "Map<BotState, Long>" },
          { "nome": "totalConversas", "tipo": "long"                }
        ]
      },
      {
        "nome": "FluxoTemplateResponse",
        "campos": [
          { "nome": "chave",    "tipo": "String" },
          { "nome": "texto",    "tipo": "String" },
          { "nome": "descricao","tipo": "String" }
        ]
      },
      {
        "nome": "FluxoNodeResponse",
        "campos": [
          { "nome": "id",                  "tipo": "String"                       },
          { "nome": "label",               "tipo": "String"                       },
          { "nome": "estado",              "tipo": "String"                       },
          { "nome": "tipo",                "tipo": "TipoNode"                     },
          { "nome": "posX",                "tipo": "int"                          },
          { "nome": "posY",                "tipo": "int"                          },
          { "nome": "mensagens",           "tipo": "List<FluxoTemplateResponse>"  },
          { "nome": "equipeTransferencia", "tipo": "String"                       },
          { "nome": "horarioAtendimento",  "tipo": "String"                       }
        ]
      },
      {
        "nome": "FluxoArestaResponse",
        "campos": [
          { "nome": "id",       "tipo": "String" },
          { "nome": "de",       "tipo": "String" },
          { "nome": "para",     "tipo": "String" },
          { "nome": "condicao", "tipo": "String" },
          { "nome": "label",    "tipo": "String" }
        ]
      },
      {
        "nome": "FluxoBotResponse",
        "campos": [
          { "nome": "nodes",   "tipo": "List<FluxoNodeResponse>"  },
          { "nome": "arestas", "tipo": "List<FluxoArestaResponse>"}
        ]
      }
    ]
  },

  "endpoints": [
    {
      "tag": "Dashboard",
      "descricao": "Indicadores operacionais do bot",
      "rotas": [
        {
          "metodo": "GET",
          "path": "/dashboard/metricas",
          "operacao": "Buscar métricas operacionais",
          "descricao": "Retorna a contagem de conversas por BotState e o total de conversas registradas.",
          "requestDto": null,
          "responseDto": "DashboardMetricasResponse",
          "responseStatus": 200,
          "paginado": false,
          "autenticacao": false
        }
      ]
    },
    {
      "tag": "Conversas",
      "descricao": "Gestão e visualização das conversas ativas",
      "rotas": [
        {
          "metodo": "GET",
          "path": "/conversas",
          "operacao": "Listar conversas",
          "descricao": "Retorna lista paginada de todas as conversas com seu estado atual.",
          "requestDto": null,
          "responseDto": "ConversaResumoResponse",
          "responseStatus": 200,
          "paginado": true,
          "autenticacao": false
        },
        {
          "metodo": "GET",
          "path": "/conversas/{phone}",
          "operacao": "Detalhe da conversa",
          "descricao": "Retorna o estado atual e o histórico completo de mensagens de uma conversa.",
          "requestDto": null,
          "responseDto": "ConversaDetalheResponse",
          "responseStatus": 200,
          "paginado": false,
          "autenticacao": false
        }
      ]
    },
    {
      "tag": "Templates",
      "descricao": "Gestão dos textos de mensagens do bot com auditoria",
      "rotas": [
        {
          "metodo": "GET",
          "path": "/templates",
          "operacao": "Listar todos os templates",
          "descricao": "Retorna todos os templates de mensagem cadastrados.",
          "requestDto": null,
          "responseDto": "BotTemplateResponse",
          "responseStatus": 200,
          "paginado": false,
          "autenticacao": false
        },
        {
          "metodo": "GET",
          "path": "/templates/{chave}",
          "operacao": "Buscar template por chave",
          "descricao": "Retorna um template específico pela chave (ex: menu.inicial.boas_vindas).",
          "requestDto": null,
          "responseDto": "BotTemplateResponse",
          "responseStatus": 200,
          "paginado": false,
          "autenticacao": false
        },
        {
          "metodo": "PUT",
          "path": "/templates/{chave}",
          "operacao": "Atualizar texto do template",
          "descricao": "Atualiza o texto de um template e registra a alteração na auditoria.",
          "requestDto": "AtualizarTemplateRequest",
          "responseDto": "BotTemplateResponse",
          "responseStatus": 200,
          "paginado": false,
          "autenticacao": false
        },
        {
          "metodo": "GET",
          "path": "/templates/{chave}/auditoria",
          "operacao": "Histórico de alterações do template",
          "descricao": "Retorna o log de todas as alterações feitas em um template, em ordem decrescente.",
          "requestDto": null,
          "responseDto": "BotTemplateAuditoriaResponse",
          "responseStatus": 200,
          "paginado": false,
          "autenticacao": false
        }
      ]
    }
  ,
    {
      "tag": "Fluxo",
      "descricao": "Estrutura visual do fluxo de atendimento do bot (nodes + arestas)",
      "rotas": [
        {
          "metodo": "GET",
          "path": "/fluxo",
          "operacao": "Obter fluxo do bot",
          "descricao": "Retorna o grafo completo do fluxo de atendimento: nós com seus templates resolvidos do BD e arestas com as condições de transição. Usado para renderizar o editor visual estilo Typebot.",
          "requestDto": null,
          "responseDto": "FluxoBotResponse",
          "responseStatus": 200,
          "paginado": false,
          "autenticacao": false
        }
      ]
    }
  ]
}
