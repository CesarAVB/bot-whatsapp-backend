{
  "projeto": {
    "nome": "bot-whatsapp",
    "pacote": "br.com.sistema.bot",
    "descricao": "Painel administrativo do bot de atendimento WhatsApp da ASB Telecom",
    "apiBaseUrl": "/api/v1",
    "contextPath": "/api/v1"
  },

  "enums": [
    {
      "nome": "TipoNode",
      "descricao": "Tipo comportamental de cada nó no fluxo dinâmico",
      "valores": ["MENU", "AGUARDA_INPUT", "CONFIRMACAO", "TRANSFERENCIA", "RESULTADO_API", "MENSAGEM", "ENCERRAMENTO"]
    },
    {
      "nome": "Direcao",
      "valores": ["RECEBIDA", "ENVIADA"]
    }
  ],

  "dtos": {
    "requests": [
      {
        "nome": "AtualizarTemplateRequest",
        "campos": [
          { "nome": "texto",      "tipo": "String", "obrigatorio": true,  "validacoes": ["NotBlank"] },
          { "nome": "alteradoPor","tipo": "String", "obrigatorio": false, "validacoes": ["Size(max=100)"] }
        ]
      },
      {
        "nome": "AtualizarNodePosicaoRequest",
        "campos": [
          { "nome": "posX",  "tipo": "Integer", "obrigatorio": true,  "validacoes": ["NotNull"] },
          { "nome": "posY",  "tipo": "Integer", "obrigatorio": true,  "validacoes": ["NotNull"] },
          { "nome": "label", "tipo": "String",  "obrigatorio": false, "validacoes": [] }
        ]
      },
      {
        "nome": "CriarConexaoRequest",
        "campos": [
          { "nome": "deNodeId",  "tipo": "UUID",   "obrigatorio": true, "validacoes": ["NotBlank"] },
          { "nome": "paraNodeId","tipo": "UUID",   "obrigatorio": true, "validacoes": ["NotBlank"] },
          { "nome": "condicao",  "tipo": "String", "obrigatorio": true, "validacoes": ["NotBlank"] },
          { "nome": "label",     "tipo": "String", "obrigatorio": false,"validacoes": [] },
          { "nome": "ordem",     "tipo": "int",    "obrigatorio": false,"validacoes": [] }
        ]
      },
      {
        "nome": "AtualizarConexaoRequest",
        "campos": [
          { "nome": "condicao", "tipo": "String", "obrigatorio": true, "validacoes": ["NotBlank"] },
          { "nome": "label",    "tipo": "String", "obrigatorio": false,"validacoes": [] },
          { "nome": "ordem",    "tipo": "int",    "obrigatorio": false,"validacoes": [] }
        ]
      },
      {
        "nome": "AdicionarMensagemRequest",
        "campos": [
          { "nome": "templateChave", "tipo": "String", "obrigatorio": true, "validacoes": ["NotBlank"] },
          { "nome": "ordem",         "tipo": "int",    "obrigatorio": false,"validacoes": [] }
        ]
      }
    ],
    "responses": [
      {
        "nome": "BotTemplateResponse",
        "campos": [
          { "nome": "chave",     "tipo": "String"        },
          { "nome": "texto",     "tipo": "String"        },
          { "nome": "descricao", "tipo": "String"        },
          { "nome": "ativo",     "tipo": "boolean"       },
          { "nome": "createdAt", "tipo": "LocalDateTime" },
          { "nome": "updatedAt", "tipo": "LocalDateTime" }
        ]
      },
      {
        "nome": "BotTemplateAuditoriaResponse",
        "campos": [
          { "nome": "templateChave", "tipo": "String"        },
          { "nome": "textoAnterior", "tipo": "String"        },
          { "nome": "textoNovo",     "tipo": "String"        },
          { "nome": "alteradoPor",   "tipo": "String"        },
          { "nome": "alteradoEm",    "tipo": "LocalDateTime" }
        ]
      },
      {
        "nome": "MensagemHistoricoResponse",
        "campos": [
          { "nome": "direcao",   "tipo": "Direcao"       },
          { "nome": "conteudo",  "tipo": "String"        },
          { "nome": "createdAt", "tipo": "LocalDateTime" }
        ]
      },
      {
        "nome": "ConversaResumoResponse",
        "campos": [
          { "nome": "whatsappPhone",         "tipo": "String"        },
          { "nome": "currentNodeKey",        "tipo": "String"        },
          { "nome": "transferidoParaHumano", "tipo": "boolean"       },
          { "nome": "chatwootConversationId","tipo": "Long"          },
          { "nome": "createdAt",             "tipo": "LocalDateTime" },
          { "nome": "updatedAt",             "tipo": "LocalDateTime" }
        ]
      },
      {
        "nome": "ConversaDetalheResponse",
        "campos": [
          { "nome": "whatsappPhone",         "tipo": "String"                         },
          { "nome": "currentNodeKey",        "tipo": "String"                         },
          { "nome": "transferidoParaHumano", "tipo": "boolean"                        },
          { "nome": "chatwootConversationId","tipo": "Long"                           },
          { "nome": "createdAt",             "tipo": "LocalDateTime"                  },
          { "nome": "updatedAt",             "tipo": "LocalDateTime"                  },
          { "nome": "historico",             "tipo": "List<MensagemHistoricoResponse>" }
        ]
      },
      {
        "nome": "DashboardMetricasResponse",
        "campos": [
          { "nome": "totalPorEstado", "tipo": "Map<String, Long>", "descricao": "nodeKey → contagem" },
          { "nome": "totalConversas", "tipo": "long"              }
        ]
      },
      {
        "nome": "FluxoTemplateResponse",
        "campos": [
          { "nome": "chave",    "tipo": "String" },
          { "nome": "texto",    "tipo": "String" },
          { "nome": "descricao","tipo": "String" }
        ]
      },
      {
        "nome": "FluxoNodeResponse",
        "campos": [
          { "nome": "id",                  "tipo": "String"                      },
          { "nome": "label",               "tipo": "String"                      },
          { "nome": "estado",              "tipo": "String"                      },
          { "nome": "tipo",                "tipo": "TipoNode"                    },
          { "nome": "posX",                "tipo": "int"                         },
          { "nome": "posY",                "tipo": "int"                         },
          { "nome": "mensagens",           "tipo": "List<FluxoTemplateResponse>" },
          { "nome": "equipeTransferencia", "tipo": "String"                      },
          { "nome": "horarioAtendimento",  "tipo": "String"                      }
        ]
      },
      {
        "nome": "FluxoArestaResponse",
        "campos": [
          { "nome": "id",       "tipo": "String" },
          { "nome": "de",       "tipo": "String" },
          { "nome": "para",     "tipo": "String" },
          { "nome": "condicao", "tipo": "String" },
          { "nome": "label",    "tipo": "String" }
        ]
      },
      {
        "nome": "FluxoBotResponse",
        "campos": [
          { "nome": "nodes",   "tipo": "List<FluxoNodeResponse>"  },
          { "nome": "arestas", "tipo": "List<FluxoArestaResponse>"}
        ]
      }
    ]
  },

  "endpoints": [
    {
      "tag": "Dashboard",
      "descricao": "Indicadores operacionais do bot",
      "rotas": [
        {
          "metodo": "GET",
          "path": "/dashboard/metricas",
          "operacao": "Buscar métricas operacionais",
          "descricao": "Retorna a contagem de conversas por nodeKey e o total de conversas.",
          "requestDto": null,
          "responseDto": "DashboardMetricasResponse",
          "responseStatus": 200,
          "paginado": false,
          "autenticacao": false
        }
      ]
    },
    {
      "tag": "Conversas",
      "descricao": "Gestão e visualização das conversas ativas",
      "rotas": [
        {
          "metodo": "GET",
          "path": "/conversas",
          "operacao": "Listar conversas",
          "requestDto": null,
          "responseDto": "ConversaResumoResponse",
          "responseStatus": 200,
          "paginado": true,
          "autenticacao": false
        },
        {
          "metodo": "GET",
          "path": "/conversas/{phone}",
          "operacao": "Detalhe da conversa",
          "requestDto": null,
          "responseDto": "ConversaDetalheResponse",
          "responseStatus": 200,
          "paginado": false,
          "autenticacao": false
        }
      ]
    },
    {
      "tag": "Templates",
      "descricao": "Gestão dos textos de mensagens do bot com auditoria",
      "rotas": [
        {
          "metodo": "GET",   "path": "/templates",
          "operacao": "Listar todos os templates",
          "requestDto": null, "responseDto": "BotTemplateResponse",
          "responseStatus": 200, "paginado": false, "autenticacao": false
        },
        {
          "metodo": "GET",   "path": "/templates/{chave}",
          "operacao": "Buscar template por chave",
          "requestDto": null, "responseDto": "BotTemplateResponse",
          "responseStatus": 200, "paginado": false, "autenticacao": false
        },
        {
          "metodo": "PUT",   "path": "/templates/{chave}",
          "operacao": "Atualizar texto do template",
          "requestDto": "AtualizarTemplateRequest", "responseDto": "BotTemplateResponse",
          "responseStatus": 200, "paginado": false, "autenticacao": false
        },
        {
          "metodo": "GET",   "path": "/templates/{chave}/auditoria",
          "operacao": "Histórico de alterações do template",
          "requestDto": null, "responseDto": "BotTemplateAuditoriaResponse",
          "responseStatus": 200, "paginado": false, "autenticacao": false
        }
      ]
    },
    {
      "tag": "Fluxo",
      "descricao": "Editor visual do fluxo de atendimento — leitura e edição de nós, balões e conexões",
      "rotas": [
        {
          "metodo": "GET",  "path": "/fluxo",
          "operacao": "Obter fluxo completo",
          "descricao": "Retorna todos os nós (com textos resolvidos do BD) e arestas. Base para o editor React Flow.",
          "requestDto": null, "responseDto": "FluxoBotResponse",
          "responseStatus": 200, "paginado": false, "autenticacao": false
        },
        {
          "metodo": "PATCH", "path": "/fluxo/nodes/{id}",
          "operacao": "Atualizar posição e label do nó",
          "descricao": "Salva a posição (posX/posY) após o usuário arrastar o nó no canvas.",
          "requestDto": "AtualizarNodePosicaoRequest", "responseDto": null,
          "responseStatus": 204, "paginado": false, "autenticacao": false
        },
        {
          "metodo": "POST",   "path": "/fluxo/nodes/{nodeId}/mensagens",
          "operacao": "Adicionar balão ao nó",
          "requestDto": "AdicionarMensagemRequest", "responseDto": null,
          "responseStatus": 204, "paginado": false, "autenticacao": false
        },
        {
          "metodo": "PATCH",  "path": "/fluxo/mensagens/{id}/ordem",
          "operacao": "Reordenar balão dentro do nó",
          "descricao": "Query param: ?ordem=2",
          "requestDto": null, "responseDto": null,
          "responseStatus": 204, "paginado": false, "autenticacao": false
        },
        {
          "metodo": "DELETE", "path": "/fluxo/mensagens/{id}",
          "operacao": "Remover balão",
          "requestDto": null, "responseDto": null,
          "responseStatus": 204, "paginado": false, "autenticacao": false
        },
        {
          "metodo": "POST",   "path": "/fluxo/conexoes",
          "operacao": "Criar conexão (seta) entre nós",
          "requestDto": "CriarConexaoRequest", "responseDto": null,
          "responseStatus": 204, "paginado": false, "autenticacao": false
        },
        {
          "metodo": "PUT",    "path": "/fluxo/conexoes/{id}",
          "operacao": "Atualizar condição e label de uma seta",
          "requestDto": "AtualizarConexaoRequest", "responseDto": null,
          "responseStatus": 204, "paginado": false, "autenticacao": false
        },
        {
          "metodo": "DELETE", "path": "/fluxo/conexoes/{id}",
          "operacao": "Remover conexão (seta)",
          "requestDto": null, "responseDto": null,
          "responseStatus": 204, "paginado": false, "autenticacao": false
        }
      ]
    }
  ]
}
